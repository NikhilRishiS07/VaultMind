<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F40B1112"
    android:padding="20dp">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.4"
        android:background="@drawable/bg_unlock_chip"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.22"
                android:text="VAULTMIND"
                android:textColor="@color/vault_text_primary"
                android:textSize="27sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Digital Sanctuary Security"
                android:textColor="#99DCE4E5"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_unlock_panel"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textAllCaps="true"
                android:textColor="@color/vault_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="#00000000"
                app:boxBackgroundMode="filled"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/unlockUsernameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_unlock_field"
                    android:hint="Enter your identity"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="14dp"
                    android:singleLine="true"
                    android:textColor="@color/vault_text_primary"
                    android:textColorHint="#66849595" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Password"
                android:textAllCaps="true"
                android:textColor="@color/vault_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="#00000000"
                app:boxBackgroundMode="filled"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/unlockPasswordInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_unlock_field"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="14dp"
                    android:singleLine="true"
                    android:textColor="@color/vault_text_primary"
                    android:textColorHint="#66849595" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/unlockErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Invalid credentials"
                android:textColor="#FFFFB4AB"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/unlockLoginButtonContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <View
                    android:id="@+id/unlockLoginCircle"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:alpha="0"
                    android:background="@drawable/bg_unlock_login_circle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/unlockLoginButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_unlock_login_button"
                    android:gravity="center"
                    android:paddingVertical="14dp"
                    android:text="LOGIN"
                    android:textAllCaps="true"
                    android:textColor="#FF00F0FF"
                    android:textStyle="bold"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="999dp"
                    app:icon="@android:drawable/ic_media_next"
                    app:iconGravity="textEnd"
                    app:iconPadding="8dp"
                    app:iconTint="#FF00F0FF" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/unlockBiometricButtonContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <View
                    android:id="@+id/unlockBiometricCircle"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:alpha="0"
                    android:background="@drawable/bg_unlock_login_circle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/unlockBiometricButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_unlock_login_button"
                    android:gravity="center"
                    android:paddingVertical="14dp"
                    android:text="UNLOCK WITH BIOMETRICS"
                    android:textAllCaps="true"
                    android:textColor="#FF00F0FF"
                    android:textStyle="bold"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="999dp"
                    app:icon="@android:drawable/ic_media_next"
                    app:iconGravity="textEnd"
                    app:iconPadding="8dp"
                    app:iconTint="#FF00F0FF" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center"
                android:text="Advanced encryption using"
                android:textAllCaps="true"
                android:textColor="#80DCE4E5"
                android:textSize="10sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_unlock_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="AES-GCM"
                android:textAllCaps="true"
                android:textColor="#99DCE4E5"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_unlock_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="PBKDF2-HMAC-SHA256"
                android:textAllCaps="true"
                android:textColor="#99DCE4E5"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
