<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vault_background"
    android:fillViewport="true"
    android:paddingBottom="96dp"
    tools:context=".passwords.PasswordsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password Vault"
            android:textColor="@color/vault_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Secure cards, hidden passwords, reveal and copy actions."
            android:textColor="@color/vault_text_secondary" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/vault_surface"
            app:boxCornerRadiusBottomEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusTopStart="18dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/passwordsSearchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search passwords..."
                android:textColor="@color/vault_text_primary"
                android:textColorHint="@color/vault_text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/vault_surface"
            app:cardCornerRadius="24dp"
            app:strokeColor="#1FFFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vault Health"
                        android:textAllCaps="true"
                        android:textColor="@color/vault_text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="High Security"
                        android:textColor="@color/vault_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/vaultHealthSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="All entries are encrypted."
                        android:textColor="@color/vault_text_secondary" />
                </LinearLayout>

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/vaultSecurityIndicator"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="82"
                    android:progressTint="@color/vault_primary"
                    app:trackThickness="8dp"
                    app:trackColor="#1AFFFFFF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/passwordsRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_password_entry" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addPasswordFab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Add Password"
            app:backgroundTint="@color/vault_primary"
            android:textColor="@color/vault_background"
            app:cornerRadius="999dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>